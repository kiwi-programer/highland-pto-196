# Backend API
PORT=4000

# Auth0 API validation (enables requireAuth on write routes)
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://highland-pto-api

# Auth0 Management API (enables /api/users add/remove/list)
AUTH0_M2M_CLIENT_ID=your_machine_to_machine_client_id
AUTH0_M2M_CLIENT_SECRET=your_machine_to_machine_client_secret
AUTH0_DB_CONNECTION=Username-Password-Authentication
